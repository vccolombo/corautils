[user]
	; email = 
	name = Victor Colombo
[alias]
	uncommit = reset HEAD^
	lg = log --abbrev-commit -30 --graph --pretty=format:\"%C(red)%h%Creset -%C(yellow)%d%Creset %s %C(green)(%cr)%Creset %C(bold blue)[%an]%Creset\"
	st = status -sb
	gl = config --global -l
	last = log -1 HEAD --stat
	pr = pull --rebase=merges --autostash
[core]
	pager = less -FRX
[fetch]
	prune = true